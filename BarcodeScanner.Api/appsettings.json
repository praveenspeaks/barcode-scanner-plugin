{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ScannerOptions": {
    "EnablePreprocessing": true,
    "EnableMlDetection": false,
    "MaxResults": 50,
    "ModelPath": null,
    "Preprocessing": {
      "Denoise": true,
      "EnhanceContrast": true,
      "Sharpen": true,
      "AutoRotate": true,
      "Binarize": true
    }
  }
}
